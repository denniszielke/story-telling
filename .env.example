# Azure AI Foundry project
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>
AZURE_AI_PROJECT_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.MachineLearningServices/workspaces/<project>

# Model deployment
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_ENDPOINT=https://<your-account>.openai.azure.com/
OPENAI_API_VERSION=2024-05-01-preview

# Azure Container Registry (for hosted agents)
AZURE_CONTAINER_REGISTRY_ENDPOINT=<registry>.azurecr.io

# Azure AI Search (for product-guide vector search)
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_INDEX_NAME=bike-products
AZURE_SEARCH_API_KEY=

# Bing Custom Search (for support-hotline web research)
BING_CUSTOM_GROUNDING_CONNECTION_NAME=
BING_CUSTOM_GROUNDING_CONFIG_INSTANCE_NAME=default

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=
